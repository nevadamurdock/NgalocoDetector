name: Build NgalocoDetector APK

on:
  push:
    branches: [ "main" ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
        with:
          submodules: recursive

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
          cache: gradle

      - name: Create local.properties
        run: |
          touch local.properties
          echo "sdk.dir=$ANDROID_SDK_ROOT" > local.properties

      - name: Fix Missing LSS Header
        run: |
          mkdir -p library/src/main/cpp/include
          curl -Lo library/src/main/cpp/include/linux_syscall_support.h "https://chromium.googlesource.com/linux-syscall-support/+/master/linux_syscall_support.h?format=TEXT" | base64 --decode > library/src/main/cpp/include/linux_syscall_support.h
          cp library/src/main/cpp/include/linux_syscall_support.h library/src/main/cpp/src/linux_syscall_support.h

      - name: Grant Execute Permission
        run: chmod +x gradlew

      - name: Build Debug APK
        run: ./gradlew assembleDebug

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: NgalocoDetector-NewPackage-APK
          path: app/build/outputs/apk/debug/*.apk