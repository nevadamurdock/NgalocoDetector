name: Build NgalocoDetector APK

on:
  push:
    branches: [ "main" ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
        with:
          submodules: recursive

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
          cache: gradle

      - name: Create local.properties
        run: |
          touch local.properties
          echo "sdk.dir=$ANDROID_SDK_ROOT" > local.properties

      - name: Fix Missing LSS Header
        run: |
          mkdir -p library/src/main/cpp/include
          curl -Lo library/src/main/cpp/include/linux_syscall_support.h "https://chromium.googlesource.com/linux-syscall-support/+/master/linux_syscall_support.h?format=TEXT" | base64 --decode > library/src/main/cpp/include/linux_syscall_support.h
          cp library/src/main/cpp/include/linux_syscall_support.h library/src/main/cpp/src/linux_syscall_support.h || true

      - name: Validate and Repair Gradle Wrapper
        run: |
          # Jika jar hilang atau rusak, kita download versi standar agar build tetap jalan
          if [ ! -f "gradle/wrapper/gradle-wrapper.jar" ]; then
            echo "Gradle wrapper jar not found! Downloading..."
            curl -Lo gradle/wrapper/gradle-wrapper.jar https://github.com/gradle/gradle/raw/v7.5.0/gradle/wrapper/gradle-wrapper.jar
          fi

      - name: Grant Execute Permission
        run: chmod +x gradlew

      - name: Build Debug APK
        run: ./gradlew assembleDebug --stacktrace

      - name: Get Current Date
        id: date
        run: echo "date=$(date +'%Y%m%d-%H%M')" >> $GITHUB_OUTPUT

      - name: Upload APK Artifact
        uses: actions/upload-artifact@v4
        with:
          name: NgalocoDetector-${{ steps.date.outputs.date }}-APK
          path: app/build/outputs/apk/debug/*.apk